WAN_ROUTER_API_KEY=your_wan_api_key_here
LOCAL_ROUTER_API_KEY=your_local_api_key_here
LOCAL_ROUTER_LAN_ADR=192.168.1.1
DRY_RUN=false
# SYNC_SCHEDULE=*/5 * * * *
SYNC_TAG=unifi-sync
# Required when both API keys belong to the same UniFi Cloud account
# (both would auto-discover the same hosts[0] otherwise).
# Find host IDs in the DRY_RUN log: "[LOCAL] Using host: <id>"
# WAN_ROUTER_HOST_ID=
# LOCAL_ROUTER_HOST_ID=
